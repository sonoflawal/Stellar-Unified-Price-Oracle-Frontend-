// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`snapshots > empty 1`] = `
<div
  class="h-80 bg-gray-100 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 rounded-xl flex items-center justify-center text-gray-400 dark:text-gray-500"
>
  No historical data available
</div>
`;

exports[`snapshots > loading 1`] = `
<div
  aria-label="Loading chart"
  class="h-80 bg-gray-100 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 rounded-xl flex items-center justify-center"
  role="status"
>
  <div
    class="animate-spin w-8 h-8 border-2 border-cyan-400 border-t-transparent rounded-full"
  />
</div>
`;

exports[`snapshots > with data 1`] = `
<div
  class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-4"
>
  <h3
    class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-4"
  >
    BTC/USD
     Price History
  </h3>
  <div
    class="h-80"
  >
    <div
      class="recharts-responsive-container"
      style="width: 100%; height: 100%; min-width: 0;"
    />
  </div>
</div>
`;
